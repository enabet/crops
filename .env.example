# Shared
ENVIRONMENT=local
DJANGO_SECRET_KEY=change-me-for-production
DJANGO_DEBUG=True
BACKEND_PORT=8001
POSTGRES_HOST_PORT=5433
ALLOWED_HOSTS=*,localhost,127.0.0.1,backend,192.168.100.186,172.16.1.13
FRONTEND_URL=http://localhost:5173
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.100.186:5173,http://172.16.1.13:5173

# PostgreSQL + PostGIS
POSTGRES_DB=cardi_platform
POSTGRES_USER=cardi
POSTGRES_PASSWORD=cardi_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / async
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Demo tenant defaults
DEFAULT_COUNTRY_CODE=BZ
DEFAULT_TENANT_SCHEMA=belize
SEED_DEMO_DATA=false
